---
const pathname = Astro.url.pathname

const links = [
  { href: "/", label: "Inicio" },
  { href: "/jefes", label: "Jefes" },
  { href: "/enemigos", label: "Criaturas" },
  { href: "/instrumentos", label: "Instrumentos" },
  { href: "/zonas", label: "Zonas" },
]

function isCurrent(href: string) {
  if (href === "/") return pathname === "/"
  return pathname.startsWith(href)
}
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-[#06080d]/80 backdrop-blur-sm"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6"
  >
    <a href="/" class="flex items-center gap-2.5 group">
      <img
        class="block h-5 w-5 transition group-hover:scale-110"
        src="/images/silksong.ico"
        alt="silksong wiki icon"
      />

      <span
        class="block leading-none font-[Cinzel] text-sm tracking-widest text-white/90 uppercase"
      >
        Silksong Wiki
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-1" role="list">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`px-3 py-1.5 rounded-lg font-[Cinzel] text-[0.7rem] tracking-widest uppercase transition
              ${
                isCurrent(href)
                  ? "text-[#d4b46a] bg-[#d4b46a]/10"
                  : "text-white/50 hover:text-white/90 hover:bg-white/5"
              }`}
              aria-current={isCurrent(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      id="nav-toggle"
      class="md:hidden text-white/50 hover:text-white p-2 rounded-lg transition hover:bg-white/5"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </nav>

  <div
    id="nav-mobile"
    class="hidden md:hidden border-t border-white/10 px-4 pb-4"
  >
    <ul class="flex flex-col gap-1 pt-3" role="list">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`block px-3 py-2 rounded-lg font-[Cinzel] text-[0.7rem] tracking-widest uppercase transition
              ${
                isCurrent(href)
                  ? "text-[#d4b46a] bg-[#d4b46a]/10"
                  : "text-white/50 hover:text-white/90 hover:bg-white/5"
              }`}
              aria-current={isCurrent(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("nav-toggle")
  const menu = document.getElementById("nav-mobile")
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false
    btn.setAttribute("aria-expanded", String(open))
  })
</script>
