---
import Layout from "@/layouts/Layout.astro"
import Background from "@/components/Background.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import { getCollection, getEntry } from "astro:content"
import { Image } from "astro:assets"

export async function getStaticPaths() {
  const docs = await getCollection("jefes")
  return docs.map((d) => ({ params: { slug: d.slug } }))
}

const { slug } = Astro.params
const entry = await getEntry("jefes", slug!)
if (!entry) return Astro.redirect("/jefes")

const { data } = entry
const { Content } = await entry.render()
---

<Layout title={data.title}>
  <Background />

  <section class="mx-auto max-w-4xl px-4 pt-10 pb-4">
    <Breadcrumb
      crumbs={[
        { href: "/", label: "Inicio" },
        { href: "/jefes", label: "Jefes" },
        { label: data.title },
      ]}
    />
    <h1 class="font-[Cinzel] text-3xl md:text-5xl text-white">{data.title}</h1>

    {
      Array.isArray(data.tags) && data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {data.tags.map((t) => (
            <span class="text-[11px] px-2 py-1 rounded-full border border-white/10 text-white/70 bg-white/[0.02]">
              {t}
            </span>
          ))}
        </div>
      )
    }
  </section>
  {
    data.cover?.src && (
      <div class="mx-auto max-w-4xl px-4 mt-6">
        <div class="relative w-full h-72 rounded-2xl border border-white/10 bg-white/[0.02] overflow-hidden flex items-center justify-center">
          <img
            src={data.cover.src}
            alt={data.cover.alt}
            width={800}
            height={400}
            class="max-h-64 max-w-[60%] object-contain transition-opacity duration-500 opacity-0 onload"
            loading="lazy"
            onload="this.classList.remove('opacity-0')"
          />
        </div>
      </div>
    )
  }

  <section class="mx-auto max-w-4xl px-4 py-8">
    <article class="prose prose-invert max-w-none">
      <Content />
    </article>
  </section>
</Layout>
