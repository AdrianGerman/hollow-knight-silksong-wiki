---
import Layout from "@/layouts/Layout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import { getCollection, getEntry } from "astro:content"

export async function getStaticPaths() {
  const docs = await getCollection("habilidades")
  return docs.map((d) => ({ params: { slug: d.slug } }))
}

const { slug } = Astro.params
const entry = await getEntry("habilidades", slug!)
if (!entry) return Astro.redirect("/habilidades")

const { data } = entry
const { Content } = await entry.render()

const tipoMap = {
  Ofensiva: {
    dot: "bg-red-400",
    cls: "border-red-400/30 text-red-400 bg-red-400/10",
  },
  Defensiva: {
    dot: "bg-blue-400",
    cls: "border-blue-400/30 text-blue-400 bg-blue-400/10",
  },
  Movilidad: {
    dot: "bg-yellow-400",
    cls: "border-yellow-400/30 text-yellow-400 bg-yellow-400/10",
  },
  Utilidad: {
    dot: "bg-white/40",
    cls: "border-white/20 text-white/60 bg-white/5",
  },
} as const

const tipoInfo = data.tipo ? tipoMap[data.tipo] : null
---

<Layout title={`${data.title} — Silksong Wiki`}>
  <main class="mx-auto max-w-4xl px-4 pt-8 pb-16 animate-fade-up">
    <Breadcrumb
      crumbs={[
        { href: "/", label: "Inicio" },
        { href: "/habilidades", label: "Habilidades de Seda" },
        { label: data.title },
      ]}
    />

    <h1 class="font-[Cinzel] text-3xl md:text-5xl text-(--color-ink) mt-4">
      {data.title}
    </h1>

    {
      data.excerpt && (
        <p class="mt-3 text-(--color-ink-muted) leading-relaxed max-w-2xl">
          {data.excerpt}
        </p>
      )
    }

    <div class="mt-4 flex flex-wrap gap-2">
      {
        tipoInfo && data.tipo && (
          <span
            class={`inline-flex items-center gap-1.5 text-[11px] px-2.5 py-1 rounded-full border ${tipoInfo.cls}`}
          >
            <span
              class={`h-1.5 w-1.5 rounded-full ${tipoInfo.dot}`}
              aria-hidden="true"
            />
            {data.tipo}
          </span>
        )
      }
      {
        data.acto && (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-(--color-accent)/30 text-(--color-accent) bg-(--color-accent-glow)">
            {data.acto}
          </span>
        )
      }
      {
        data.seda && (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-white/10 text-(--color-ink-muted) bg-white/[0.02]">
            Coste: {data.seda} {data.seda === 1 ? "seda" : "sedas"}
          </span>
        )
      }
      {
        data.ubicacion && (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-white/10 text-(--color-ink-muted) bg-white/[0.02]">
            {data.ubicacion}
          </span>
        )
      }
      {
        data.tags.map((t) => (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-white/10 text-(--color-ink-muted) bg-white/[0.02]">
            {t}
          </span>
        ))
      }
    </div>

    {
      data.cover?.src && (
        <div class="mt-6 w-full h-72 rounded-2xl border border-white/10 bg-white/[0.02] overflow-hidden flex items-center justify-center">
          <img
            src={data.cover.src}
            alt={data.cover.alt ?? data.title}
            class="max-h-64 max-w-[60%] object-contain opacity-0 transition-opacity duration-500"
            loading="lazy"
            onload="this.classList.remove('opacity-0')"
          />
        </div>
      )
    }

    {
      (data.seda || data.ubicacion || data.acto) && (
        <div class="mt-6 card p-5">
          <h2 class="font-[Cinzel] text-sm text-(--color-ink) mb-4 tracking-wide">
            Información
          </h2>
          <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {data.seda && (
              <div class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3">
                <dt class="text-[10px] uppercase tracking-[0.22em] text-(--color-ink-muted) mb-1">
                  Coste de seda
                </dt>
                <dd class="font-[Cinzel] text-xl text-(--color-accent)">
                  {data.seda}
                </dd>
              </div>
            )}
            {data.tipo && (
              <div class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3">
                <dt class="text-[10px] uppercase tracking-[0.22em] text-(--color-ink-muted) mb-1">
                  Tipo
                </dt>
                <dd class="text-sm text-(--color-ink)">{data.tipo}</dd>
              </div>
            )}
            {data.ubicacion && (
              <div class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3">
                <dt class="text-[10px] uppercase tracking-[0.22em] text-(--color-ink-muted) mb-1">
                  Ubicación
                </dt>
                <dd class="text-sm text-(--color-ink)">{data.ubicacion}</dd>
              </div>
            )}
          </dl>
        </div>
      )
    }

    <article
      class="prose prose-invert max-w-none mt-8 text-(--color-ink-muted)"
    >
      <Content />
    </article>

    <footer class="mt-10">
      <a
        href="/habilidades"
        class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2 text-sm text-(--color-ink-muted) hover:text-(--color-ink) hover:border-white/20 transition"
      >
        ← Volver a Habilidades de Seda
      </a>
    </footer>
  </main>
</Layout>
