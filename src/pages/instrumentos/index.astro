---
import Layout from "@/layouts/Layout.astro"
import SectionHeader from "@/components/SectionHeader.astro"
import EntriesGrid from "@/components/EntriesGrid.astro"
import ViewToggle from "@/components/ViewToggle.astro"
import EntriesList from "@/components/EntriesList.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import { getCollection } from "astro:content"
import type { CollectionEntry } from "astro:content"

const docs = await getCollection("instrumentos")

const normalize = (d: CollectionEntry<"instrumentos">) => ({
  href: `/${d.collection}/${d.slug}`,
  title: d.data.title,
  excerpt: d.data.excerpt ?? "",
  cover: d.data.cover?.src ?? "",
  tags: d.data.tags ?? [],
  color: d.data.color,
  obtained: d.data.obtained,
  order: d.data.order ?? 9999,
})

const items = docs.map(normalize).sort((a, b) => a.order - b.order)

const grupos = [
  {
    key: "rojo",
    label: "Rojas — Activas",
    desc: "Herramientas activas orientadas a combate (se recargan en banco).",
    dot: "bg-red-400",
    items: items.filter((i) => i.color === "rojo"),
    gridId: "grid-rojos",
    listId: "list-rojos",
  },
  {
    key: "azul",
    label: "Azules — Pasivas",
    desc: "Herramientas pasivas defensivas / supervivencia.",
    dot: "bg-blue-400",
    items: items.filter((i) => i.color === "azul"),
    gridId: "grid-azules",
    listId: "list-azules",
  },
  {
    key: "amarillo",
    label: "Amarillas — Utilidad",
    desc: "Utilidad, exploración y soporte (calidad de vida).",
    dot: "bg-yellow-400",
    items: items.filter((i) => i.color === "amarillo"),
    gridId: "grid-amarillos",
    listId: "list-amarillos",
  },
]

const sinColor = items.filter((i) => !i.color)
---

<Layout title="Instrumentos — Pharloom Archives">
  <SectionHeader
    title="Instrumentos"
    description="Herramientas, amuletos y objetos de utilidad que Hornet encuentra en su viaje."
  />

  <div class="mx-auto max-w-6xl px-4">
    <Breadcrumb
      crumbs={[{ href: "/", label: "Inicio" }, { label: "Instrumentos" }]}
    />
  </div>

  <ViewToggle />

  <div class="mx-auto max-w-6xl px-4 pb-14 space-y-10">
    <div class="mx-auto max-w-6xl px-4 pb-14 space-y-10">
      {
        grupos.map(
          ({ label, desc, dot, items: grupoItems, gridId, listId }) => (
            <section>
              <div class="mb-4 flex items-end justify-between gap-4">
                <div class="flex items-center gap-3">
                  <span
                    class={`h-3 w-3 rounded-full shrink-0 ${dot}`}
                    aria-hidden="true"
                  />
                  <div>
                    <h2 class="font-[Cinzel] text-xl text-(--color-ink)">
                      {label}
                    </h2>
                    <p class="text-sm text-(--color-ink-muted)">{desc}</p>
                  </div>
                </div>
                <span class="text-xs text-(--color-ink-muted) shrink-0">
                  {grupoItems.length}{" "}
                  {grupoItems.length === 1 ? "instrumento" : "instrumentos"}
                </span>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-4">
                {grupoItems.length > 0 ? (
                  <>
                    <div class="view-grid">
                      <EntriesGrid items={grupoItems} id={gridId} />
                    </div>
                    <div class="view-list hidden">
                      <EntriesList items={grupoItems} id={listId} />
                    </div>
                  </>
                ) : (
                  <p class="py-6 text-sm text-(--color-ink-muted)">
                    Aún no hay instrumentos en esta categoría.
                  </p>
                )}
              </div>
            </section>
          ),
        )
      }

      {
        sinColor.length > 0 && (
          <section>
            <div class="mb-4 flex items-end justify-between gap-4">
              <div class="flex items-center gap-3">
                <span
                  class="h-3 w-3 rounded-full shrink-0 bg-white/20"
                  aria-hidden="true"
                />
                <div>
                  <h2 class="font-[Cinzel] text-xl text-(--color-ink-muted)">
                    Sin clasificar
                  </h2>
                  <p class="text-sm text-(--color-ink-muted)">
                    Entradas sin <code>color</code> en el frontmatter.
                  </p>
                </div>
              </div>
              <span class="text-xs text-(--color-ink-muted) shrink-0">
                {sinColor.length}{" "}
                {sinColor.length === 1 ? "instrumento" : "instrumentos"}
              </span>
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-4">
              <div class="view-grid">
                <EntriesGrid items={sinColor} id="grid-sin-color" />
              </div>
              <div class="view-list hidden">
                <EntriesList items={sinColor} id="list-sin-color" />
              </div>
            </div>
          </section>
        )
      }
    </div>
  </div>

  <script>
    import "../../scripts/viewToggle.js"
  </script>
</Layout>
