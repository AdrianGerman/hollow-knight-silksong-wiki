---
import Layout from "@/layouts/Layout.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import { getCollection, getEntry } from "astro:content"

export async function getStaticPaths() {
  const docs = await getCollection("blasones")
  return docs.map((d) => ({ params: { slug: d.slug } }))
}

const { slug } = Astro.params
const entry = await getEntry("blasones", slug!)
if (!entry) return Astro.redirect("/blasones")

const { data } = entry
const { Content } = await entry.render()

const slotColors = {
  rojo: "bg-red-400",
  azul: "bg-blue-400",
  amarillo: "bg-yellow-400",
  blanco: "bg-white/60",
}
---

<Layout title={`${data.title} — Silksong Wiki`}>
  <main class="mx-auto max-w-4xl px-4 pt-8 pb-16 animate-fade-up">
    <Breadcrumb
      crumbs={[
        { href: "/", label: "Inicio" },
        { href: "/blasones", label: "Blasones" },
        { label: data.title },
      ]}
    />

    <h1 class="font-[Cinzel] text-3xl md:text-5xl text-(--color-ink) mt-4">
      {data.title}
    </h1>

    {
      data.excerpt && (
        <p class="mt-3 text-(--color-ink-muted) leading-relaxed max-w-2xl">
          {data.excerpt}
        </p>
      )
    }

    <div class="mt-4 flex flex-wrap gap-2">
      {
        data.acto && (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-(--color-accent)/30 text-(--color-accent) bg-(--color-accent-glow)">
            {data.acto}
          </span>
        )
      }
      {
        data.ubicacion && (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-white/10 text-(--color-ink-muted) bg-white/[0.02]">
            {data.ubicacion}
          </span>
        )
      }
      {
        data.tags.map((t) => (
          <span class="text-[11px] px-2 py-0.5 rounded-full border border-white/10 text-(--color-ink-muted) bg-white/[0.02]">
            {t}
          </span>
        ))
      }
    </div>

    {
      data.cover?.src && (
        <div class="mt-6 w-full h-72 rounded-2xl border border-white/10 bg-white/[0.02] overflow-hidden flex items-center justify-center">
          <img
            src={data.cover.src}
            alt={data.cover.alt ?? data.title}
            class="max-h-64 max-w-[60%] object-contain opacity-0 transition-opacity duration-500"
            loading="lazy"
            onload="this.classList.remove('opacity-0')"
          />
        </div>
      )
    }

    {
      data.slots && (
        <div class="mt-6 card p-5">
          <h2 class="font-[Cinzel] text-sm text-(--color-ink) mb-4 tracking-wide">
            Slots disponibles
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {(
              Object.entries(data.slots) as [keyof typeof slotColors, number][]
            ).map(([color, n]) => (
              <div class="rounded-xl border border-white/10 bg-white/[0.02] px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-2 mb-1">
                  <span
                    class={`h-2.5 w-2.5 rounded-full ${slotColors[color]}`}
                    aria-hidden="true"
                  />
                  <span class="text-xs text-(--color-ink-muted) capitalize">
                    {color}
                  </span>
                </div>
                <p class="font-[Cinzel] text-2xl text-(--color-ink)">{n}</p>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <article
      class="prose prose-invert max-w-none mt-8 text-(--color-ink-muted)"
    >
      <Content />
    </article>

    <footer class="mt-10">
      <a
        href="/blasones"
        class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.02] px-4 py-2 text-sm text-(--color-ink-muted) hover:text-(--color-ink) hover:border-white/20 transition"
      >
        ← Volver a Blasones
      </a>
    </footer>
  </main>
</Layout>
