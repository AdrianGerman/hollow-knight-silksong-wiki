---
import Layout from "@/layouts/Layout.astro"
import SectionHeader from "@/components/SectionHeader.astro"
import Breadcrumb from "@/components/Breadcrumb.astro"
import ViewToggle from "@/components/ViewToggle.astro"
import EntriesGrid from "@/components/EntriesGrid.astro"
import EntriesList from "@/components/EntriesList.astro"
import { getCollection } from "astro:content"

const docs = await getCollection("blasones")
const items = docs
  .sort((a, b) => a.data.order - b.data.order)
  .map(({ data, slug, collection }) => ({
    href: `/${collection}/${slug}`,
    title: data.title,
    excerpt: data.excerpt ?? "",
    cover: data.cover?.src ?? "",
    tags: data.tags ?? [],
  }))

const GRID_ID = "grid-blasones"
---

<Layout title="Blasones — Silksong Wiki">
  <SectionHeader
    title="Blasones"
    description="Los 7 blasones de Telalejana — el sistema de equipamiento de Hornet. Cada blasón define cuántos slots rojos, azules y amarillos tienes disponibles para tus instrumentos."
  />

  <div class="mx-auto max-w-6xl px-4">
    <Breadcrumb
      crumbs={[{ href: "/", label: "Inicio" }, { label: "Blasones" }]}
    />
  </div>

  <div class="mx-auto max-w-6xl px-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {
        [
          {
            color: "bg-red-400",
            label: "Slots Rojos",
            desc: "Instrumentos activos — se recargan en banco",
          },
          {
            color: "bg-blue-400",
            label: "Slots Azules",
            desc: "Instrumentos pasivos — siempre activos",
          },
          {
            color: "bg-yellow-400",
            label: "Slots Amarillos",
            desc: "Instrumentos de utilidad y exploración",
          },
        ].map(({ color, label, desc }) => (
          <div class="card px-4 py-3 flex items-center gap-3">
            <span
              class={`h-3 w-3 rounded-full shrink-0 ${color}`}
              aria-hidden="true"
            />
            <div>
              <p class="text-sm font-[Cinzel] text-(--color-ink)">{label}</p>
              <p class="text-xs text-(--color-ink-muted)">{desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <ViewToggle />

  <div class="mx-auto max-w-6xl px-4 pb-12">
    {
      items.length > 0 ? (
        <>
          <div class="view-grid">
            <EntriesGrid items={items} id={GRID_ID} />
          </div>
          <div class="view-list hidden">
            <EntriesList items={items} id="list-blasones" />
          </div>
        </>
      ) : (
        <div class="card p-12 text-center">
          <p class="font-[Cinzel] text-xl text-(--color-ink-muted) mb-2">
            Sin entradas aún
          </p>
          <p class="text-sm text-(--color-ink-muted) opacity-60">
            Crea archivos .md en{" "}
            <code class="text-(--color-accent)">src/content/blasones/</code>{" "}
            para empezar.
          </p>
        </div>
      )
    }
  </div>
</Layout>

<script>
  import "../../scripts/viewToggle.js"
</script>
